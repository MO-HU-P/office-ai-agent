node_modules/
dist/
# TypeScriptの増分ビルドキャッシュ(ローカルで tsc/vite build 時に生成される)
*.tsbuildinfo
__pycache__/
*.pyc
.venv/
# pytestの実行時キャッシュ(前回結果の記録。毎回再生成される)
.pytest_cache/
workspace/*
!workspace/.gitkeep
.DS_Store

# 実行時に生成される個人設定・一時ファイル
data/
.playwright-mcp/

# Claude Code のローカル設定・ガイド（公開しない。手元でのみ使用）
CLAUDE.md
.claude/

# APIキー等のシークレットを含むため、実ファイルはコミットしない
# (見本の .env.example は共有するので除外しない)
.env
!.env.example
