# このファイルは設定の見本(テンプレート)です。
# コピーして `.env` という名前で保存し、値を埋めてください。
#   Mac/Linux:  cp .env.example .env
#   Windows:    copy .env.example .env
#
# ※ 実際のキーを書いた `.env` は他人に渡さない・共有しないでください。

# WebアプリのURL: http://localhost:${APP_PORT}
APP_PORT=3000

# Ollama APIキー (クラウドのAIを使う場合に必須。ローカル利用なら空のままでOK)
# https://ollama.com/settings/keys で発行して、= の右に貼り付けてください
OLLAMA_API_KEY=

# OpenAI APIキー (任意)。OpenAIのAIを使いたい人だけ設定します。
# 設定すると、右上の設定画面で「OpenAI」を選べるようになります。空ならOpenAIは表示されません。
# https://platform.openai.com/api-keys で発行して、= の右に貼り付けてください
OPENAI_API_KEY=

# Google Gemini APIキー (任意)。GeminiのAIを使いたい人だけ設定します。
# 設定すると、右上の設定画面で「Google Gemini」を選べるようになります。空なら表示されません。
# https://aistudio.google.com/apikey で発行して、= の右に貼り付けてください
GEMINI_API_KEY=
